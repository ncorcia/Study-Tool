ANTHROPIC_API_KEY=your-api-key-here
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=your-random-secret-here
# Set to true when served over HTTPS in production, so the session cookie is HTTPS-only.
SESSION_HTTPS_ONLY=false
# Optional. Defaults to <repo_root>/data if unset. In production, point this at
# a mounted persistent disk — the web service filesystem is otherwise ephemeral,
# and the database + uploaded files would be wiped on every deploy.
DATA_DIR=
